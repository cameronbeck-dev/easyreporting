# Copy to .env and fill in. .env is git-ignored.

# Secret used to sign/encrypt the session JWT. REQUIRED.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Metadata DB (app config: users, profiles, access rules). Defaults to a local
# SQLite file if unset. Point at a libSQL/Turso or Postgres URL for a managed store.
# METADATA_DB_URL=file:./data/metadata.db
# METADATA_DB_AUTH_TOKEN=

# The owner/platform company. Admins in THIS tenant manage every company and author
# global profile templates; admins in any other company are scoped to their own.
# Defaults to the demo tenant 'easyreporting'.
# PLATFORM_TENANT_ID=easyreporting
